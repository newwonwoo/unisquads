{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "public",
  "functions": {
    "api/*.py": { "runtime": "python3.12" }
  },
  "rewrites": [
    { "source": "/api/resolve", "destination": "/api/resolve" },
    { "source": "/api/juso", "destination": "/api/juso" },
    { "source": "/api/kakao", "destination": "/api/kakao" }
  ]
}
